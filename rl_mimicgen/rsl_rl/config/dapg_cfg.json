{
  "num_envs": 2048,
  "num_steps_per_env": 40,
  "physics_timestep": 0.002,
  "max_iterations": 10000,
  "save_interval": 500,
  "difficulty_horizon": 1000,
  "obs_groups": {
    "actor": ["policy"],
    "critic": ["policy"]
  },
  "actor": {
    "class_name": "RNNModel",
    "hidden_dims": [400],
    "activation": "elu",
    "obs_normalization": false,
    "rnn_type": null,
    "rnn_hidden_dim": null,
    "rnn_num_layers": null,
    "distribution_cfg": {
      "class_name": "GaussianDistribution",
      "init_std": 0.05,
      "std_type": "log"
    }
  },
  "critic": {
    "class_name": "MLPModel",
    "hidden_dims": [256, 128, 64],
    "activation": "elu",
    "obs_normalization": false
  },
  "algorithm": {
    "class_name": "rl_mimicgen.rsl_rl.algorithms:DAPG",
    "value_loss_coef": 1.0,
    "use_clipped_value_loss": true,
    "clip_param": 0.2,
    "entropy_coef": 0.01,
    "num_learning_epochs": 5,
    "num_mini_batches": 4,
    "learning_rate": 3e-4,
    "schedule": "adaptive",
    "gamma": 0.99,
    "lam": 0.95,
    "desired_kl": 0.01,
    "max_grad_norm": 1.0,
    "rnd_cfg": null,
    "symmetry_cfg": null,
    "dapg_lambda0": 0.1,
    "dapg_lambda1": 0.998,
    "dapg_batch_size": 64,
    "demo_seq_length": 10,
    "demo_stride": null,
    "demo_filter_key": null,
    "demo_dataset_path": null,
    "demo_obs_keys": null
  },
  "video": {
    "enabled": true,
    "interval": 100,
    "width": 512,
    "height": 512,
    "fps": 20,
    "camera": null
  },
  "env_kwargs": {
    "tipover_prob": 0.1,
    "fall_off_termination": true
  }
}
