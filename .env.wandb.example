# Copy to .env.wandb (gitignored) and fill in your credentials.
# Auto-sourced by .venv/bin/activate when the file is present.
#
# Create a wandb account at https://wandb.ai, then find your API key at
# https://wandb.ai/authorize. WANDB_ENTITY is your username or team name.

export WANDB_ENTITY="your-wandb-username-or-team"
export WANDB_API_KEY="your-wandb-api-key"
